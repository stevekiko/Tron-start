#!/bin/bash

# ==========================================
# Tron-start - 极简全能启动向导 (开源发布版)
# ==========================================

# 解析脚本的绝对路径（支持软链接全局运行）
# 优先使用 readlink -f (Linux 原生支持)，在 Mac 下回退到常规 pwd
if command -v readlink >/dev/null 2>&1 && [ "$(uname -s)" != "Darwin" ]; then
    BASE_DIR=$(dirname $(readlink -f "$0"))
else
    BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi
EXEC="$BASE_DIR/profanity.x64"
TG_CONFIG="$BASE_DIR/tg_config.txt"
SPEED_FILE="$BASE_DIR/speed.txt"
RESULT_FILE="$BASE_DIR/result.txt"
RESULT_DB="$BASE_DIR/result.db"

if [ ! -f "$EXEC" ]; then
    echo "❌ 致命错误：找不到 $EXEC 核心引擎！"
    echo "💡 提示：对于新部署的环境，请先在当前目录下执行 \`make\` 进行底层编译。"
    exit 1
fi

stop_process() {
    echo "🛑 正在切断底层的 Tron-start 并发进程..."
    if pgrep -f "profanity.x64" > /dev/null; then
        pkill -9 -f "profanity.x64"
        echo "✅ Tron-start 已强制出栈并完全停止。"
    else
        echo "✅ 当前环境很干净，没有发现正在运行的 Tron-start 任务。"
    fi
}

start_process() {
    if pgrep -f "profanity.x64" > /dev/null; then
        echo "⚠️ 系统警告：检测到引擎已经在后台咆哮轰鸣了！"
        echo "请先使用 'tron stop' 将其停止后，再重新配置发车。"
        exit 1
    fi

    echo "=========================================="
    echo "       🚀 Tron-start 交互式启动部署向导"
    echo "=========================================="
    echo "请为本次算力集群选择运行模式："
    echo " [1] 💻 纯本地静默挂机模式 (断网、纯单机、经典离线安全模式)"
    echo " [2] 🤖 Telegram 机器人云托管模式 (全权由 TG 按键远控，随时随地查收益改规则)"
    echo "=========================================="
    read -p "请输入对应的数字 (1 或 2，默认回车选 1): " run_mode
    run_mode=${run_mode:-1}

    # ---------------- 模式 2: TG 云端托管 ----------------
    if [[ "$run_mode" == "2" ]]; then
        echo ""
        echo "--- 🤖 Telegram Bot 驻留配置 ---"
        TG_TOKEN=""
        TG_CHAT_ID=""
        if [ -f "$TG_CONFIG" ]; then
            source "$TG_CONFIG"
            echo "📄 读取到上一次的历史挂机配置 | Token: ${TG_TOKEN:0:10}... | Chat ID: $TG_CHAT_ID"
            read -p "是否沿用此机器人身份继续发车？(Y/n, 默认 Y): " use_saved
            use_saved=${use_saved:-Y}
            if [[ "$use_saved" == "n" || "$use_saved" == "N" ]]; then
                read -p "请输入新的 TG Bot Token (由 BotFather 获取): " TG_TOKEN
                read -p "请输入接收通知的目标 Chat ID (个人或频道组 ID): " TG_CHAT_ID
                echo "TG_TOKEN=\"$TG_TOKEN\"" > "$TG_CONFIG"
                echo "TG_CHAT_ID=\"$TG_CHAT_ID\"" >> "$TG_CONFIG"
            fi
        else
            echo "💡 提示：这是你首次配置 TG Bot 托管功能。"
            read -p "👉 请输入机器人的 TG Bot Token: " TG_TOKEN
            read -p "👉 请输入接收通知的 Chat ID (个人数字ID或群ID): " TG_CHAT_ID
            echo "TG_TOKEN=\"$TG_TOKEN\"" > "$TG_CONFIG"
            echo "TG_CHAT_ID=\"$TG_CHAT_ID\"" >> "$TG_CONFIG"
        fi
        
        # Encryption password setup
        RESULT_KEY=""
        if [ -f "$TG_CONFIG" ]; then
            RESULT_KEY_LINE=$(grep '^RESULT_KEY=' "$TG_CONFIG" | head -1)
            if [ -n "$RESULT_KEY_LINE" ]; then
                eval "$RESULT_KEY_LINE"
            fi
        fi
        if [ -z "$RESULT_KEY" ]; then
            echo ""
            echo "--- 🔐 私钥文件加密配置 (强烈建议开启) ---"
            echo "💡 若开启加密，爆出的私钥文件将使用 AES-256 加密保存，服务器被入侵也无法读取！"
            read -s -p "👉 请设置一个私钥文件加密密码 (直接回车跳过加密): " RESULT_KEY
            echo ""
            if [ -n "$RESULT_KEY" ]; then
                echo "RESULT_KEY=\"$RESULT_KEY\"" >> "$TG_CONFIG"
                echo "✅ 加密密码已保存，私钥文件将以 AES-256 加密！"
            else
                echo "⚠️  跳过加密：私钥将以明文保存（不推荐）"
            fi
        fi

        EXTRA_ARGS=""
        [ -n "$RESULT_KEY" ] && EXTRA_ARGS="--result-key \"$RESULT_KEY\" --output \"$RESULT_FILE\""

        echo "⏳ 正在将控制权移交至 C++ 纯原生层 Telegram 模块守护进程..."
        cd "$BASE_DIR"
        eval nohup $EXEC --tg-token "\"$TG_TOKEN\"" --tg-chat "\"$TG_CHAT_ID\"" $EXTRA_ARGS > /dev/null 2>&1 &
        sleep 1
        if pgrep -f "profanity.x64" > /dev/null; then
            echo "✅ 注入成功！原生机器人已在云端上线！"
            echo "📱 现在请立刻打开你的 Telegram 与 Bot 对话，随时使用菜单远程一键控盘开挖吧！"
        else
            echo "❌ 启动失败，请检查 Token 格式或防火墙网络连通性。"
        fi
        exit 0
    fi

    # ---------------- 模式 1: 纯本地并发挂机 ----------------
    echo ""
    echo "--- 🖥️  本地算力集群并发配置 ---"
    read -p "请输入匹配模式集 (默认回车使用 profanity.txt): " match_rule
    match_rule=${match_rule:-profanity.txt}
    
    if [[ "$match_rule" == "profanity.txt" ]]; then
        read -p "🔥 请输入需要匹配的极品【前缀】位数 (填0代表要求随意，默认: 0): " prefix_cnt
        prefix_cnt=${prefix_cnt:-0}
        read -p "🔥 请输入需要匹配的极品【后缀】位数 (例如爱666后缀填3，默认: 6): " suffix_cnt
        suffix_cnt=${suffix_cnt:-6}
    else
        echo "👉 你使用了自定义精准地址匹配串: $match_rule"
        read -p "这是想要匹配的前缀还是后缀？(前缀填长度，当后缀用请填0，默认: 0): " prefix_cnt
        prefix_cnt=${prefix_cnt:-0}
        suffix_cnt=0
    fi

    # Encryption password setup for local mode
    RESULT_KEY=""
    if [ -f "$TG_CONFIG" ]; then
        RESULT_KEY_LINE=$(grep '^RESULT_KEY=' "$TG_CONFIG" | head -1)
        if [ -n "$RESULT_KEY_LINE" ]; then
            eval "$RESULT_KEY_LINE"
        fi
    fi
    if [ -z "$RESULT_KEY" ]; then
        echo ""
        echo "--- 🔐 私钥文件加密配置 (强烈建议开启) ---"
        read -s -p "👉 请设置一个私钥文件加密密码 (直接回车跳过): " RESULT_KEY
        echo ""
        if [ -n "$RESULT_KEY" ]; then
            echo "RESULT_KEY=\"$RESULT_KEY\"" >> "$TG_CONFIG"
            echo "✅ 加密密码已设置！"
        fi
    fi

    ENCRYPT_ARG=""
    [ -n "$RESULT_KEY" ] && ENCRYPT_ARG="--result-key \"$RESULT_KEY\""

    rm -f "$SPEED_FILE"
    echo "⏳ 正在分配显存开启动力..."
    cd "$BASE_DIR"
    eval nohup $EXEC --matching "\"$match_rule\"" --prefix-count "$prefix_cnt" --suffix-count "$suffix_cnt" --output "\"$RESULT_FILE\"" $ENCRYPT_ARG > /dev/null 2>&1 &
    
    sleep 2
    if pgrep -f "profanity.x64" > /dev/null; then
        echo "✅ 纯本地任务启动爆算成功！程序已脱离终端潜入后台静默运转。"
        echo "👉 查看实时核爆速度:   tron -s"
        echo "👉 查看大奖爆卡结果:   tron -r"
    else
        echo "❌ 启动失败！请检查 OpenCL 驱动依赖或权限。"
    fi
}

case "$1" in
    start|--start|-start)
        start_process
        ;;
    stop|--stop|-stop)
        stop_process
        ;;
    restart|--restart|-restart)
        stop_process
        echo "-----------------------------------"
        start_process
        ;;
    -s|speed)
        if [ -f "$SPEED_FILE" ]; then cat "$SPEED_FILE"; else echo "暂无速度数据，可能程序暂未发车。"; fi
        ;;
    -r|result)
        if ! command -v sqlcipher >/dev/null 2>&1; then
            echo "❌ 缺少 sqlcipher 命令。请: apt install sqlcipher"
            exit 1
        fi
        if [ ! -f "$RESULT_DB" ]; then
            if [ -f "$RESULT_FILE" ]; then
                echo "⚠️  仍是旧版加密文件 (result.txt)。"
                echo "   启动 daemon 一次以触发自动迁移到 SQLCipher，然后再用 tron -r。"
            else
                echo "暂无爆卡结果，让子弹再飞一会。"
            fi
            exit 0
        fi

        # Always prompt for the password — never auto-read from tg_config.txt.
        # Even though the daemon needs the key in plaintext to run, interactive
        # private-key access requires "知识 + shell" 两个因子才能取出。
        read -s -p "🔐 请输入数据库密码: " DB_KEY
        echo ""
        if [ -z "$DB_KEY" ]; then
            echo "❌ 密码不能为空。"
            exit 1
        fi
        # Escape single quotes for SQL string literal.
        DB_KEY_ESC="${DB_KEY//\'/\'\'}"

        # Helper: run a SQL query, stripping the "ok" line that sqlcipher emits
        # for the PRAGMA key acknowledgement.
        sqc() { sqlcipher "$RESULT_DB" "PRAGMA key='${DB_KEY_ESC}'; $1" 2>/dev/null | grep -v '^ok$'; }

        # Helper: after showing a QR, ask whether to remove that record so the
        # user keeps "已导入"/"未导入" mentally separated.  Default = no.
        prompt_delete_after_qr() {
            local id="$1"
            echo ""
            read -p "🗑️  已成功导入钱包? 删除此记录避免下次混淆 [y/N]: " ANS
            if [[ "$ANS" =~ ^[Yy]$ ]]; then
                sqc "DELETE FROM results WHERE id = $id;" >/dev/null
                echo "✅ 已从库中删除 #$id"
            else
                echo "↩️  保留记录 #$id (下次 tron -r 仍可见)"
            fi
        }

        # Test the key + count rows.
        TOTAL=$(sqc "SELECT count(*) FROM results;")
        if [[ ! "$TOTAL" =~ ^[0-9]+$ ]]; then
            echo "❌ 解锁数据库失败 — 密码错误或文件损坏。"
            exit 1
        fi
        if [ "$TOTAL" -eq 0 ]; then
            echo "暂无爆卡结果。"
            exit 0
        fi

        # Direct mode: tron -r N → QR for record id=N
        DIRECT_ID="$2"
        if [[ "$DIRECT_ID" =~ ^[0-9]+$ ]]; then
            ROW=$(sqlcipher -separator $'\t' "$RESULT_DB" "PRAGMA key='${DB_KEY_ESC}'; SELECT private_key, address FROM results WHERE id = $DIRECT_ID;" 2>/dev/null | grep -v '^ok$')
            if [ -z "$ROW" ]; then
                echo "❌ 找不到记录 #$DIRECT_ID"
                exit 1
            fi
            PRIV="${ROW%%$'\t'*}"
            ADDR="${ROW#*$'\t'}"
            echo "🔐 #$DIRECT_ID  $ADDR"
            echo "📲 用 TronLink / imToken 等钱包扫码导入私钥："
            printf '%s' "$PRIV" | qrencode -t UTF8 -m 1
            echo "⚠️  扫描完成后建议执行 'clear' 清屏防止窥屏"
            unset PRIV ROW
            prompt_delete_after_qr "$DIRECT_ID"
            unset DB_KEY DB_KEY_ESC
            exit 0
        fi

        # Interactive mode: list last 10 + prompt for id.
        echo "🏆 最近 10 个爆号 (库内共 $TOTAL 条，私钥已隐藏):"
        sqlcipher -separator '|' "$RESULT_DB" \
            "PRAGMA key='${DB_KEY_ESC}'; SELECT id, address FROM (SELECT id, address FROM results ORDER BY id DESC LIMIT 10) ORDER BY id ASC;" 2>/dev/null \
            | grep -v '^ok$' \
            | while IFS='|' read -r ID ADDR; do
                printf "  #%-4s %s\n" "$ID" "$ADDR"
            done

        if ! command -v qrencode >/dev/null 2>&1; then
            echo ""
            echo "💡 安装 qrencode 可启用扫码导入私钥: apt install qrencode"
            unset DB_KEY DB_KEY_ESC
            exit 0
        fi

        echo ""
        read -p "📱 输入编号查看私钥二维码 (回车跳过): " IDX
        if [[ "$IDX" =~ ^[0-9]+$ ]]; then
            ROW=$(sqlcipher -separator $'\t' "$RESULT_DB" "PRAGMA key='${DB_KEY_ESC}'; SELECT private_key, address FROM results WHERE id = $IDX;" 2>/dev/null | grep -v '^ok$')
            if [ -z "$ROW" ]; then
                echo "❌ 找不到记录 #$IDX"
            else
                PRIV="${ROW%%$'\t'*}"
                ADDR="${ROW#*$'\t'}"
                echo ""
                echo "🔐 #$IDX  $ADDR"
                echo "📲 用 TronLink / imToken 等钱包扫码导入私钥："
                printf '%s' "$PRIV" | qrencode -t UTF8 -m 1
                echo "⚠️  扫描完成后建议执行 'clear' 清屏防止窥屏"
                unset PRIV ROW
                prompt_delete_after_qr "$IDX"
            fi
        fi
        unset DB_KEY DB_KEY_ESC
        ;;
    *)
        echo "=== ✨ 波场极光 (Tron-start) 启动管理器 ✨ ==="
        echo "用法: tron [命令]"
        echo "指令列表:"
        echo "  start    🚀 启动引擎: 可选 [经典纯单机] 或 [高阶TG远程全托管]"
        echo "  stop     🛑 紧急断电: 优雅停止服务器上所有的 Tron-start 并发计算"
        echo "  restart  🔄 重新发车: 一句话杀掉旧进程并让你重选配置"
        echo "  -s       ⚡ 核心算力: 偷看当前集群显卡爆发的哈希速度 (H/s)"
        echo "  -r       💰 盘点资产: 查看本地已经撞墙开奖的财富记事本"
        echo "========================================"
        ;;
esac
